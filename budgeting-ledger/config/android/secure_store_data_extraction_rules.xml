<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+: data-extraction-rules for cloud backup and device transfer.
     expo-secure-store sets the manifest attribute pointing here but does not
     write this file — it is generated by withBackupRules in app.config.js.

     Exclusions:
       sharedpref/.      - SecureStore items (OAuth tokens, DB encryption key)
       database/budgeting.db - SQLite DB containing financial data
-->
<data-extraction-rules>
  <cloud-backup>
    <exclude domain="sharedpref" path="."/>
    <exclude domain="database" path="budgeting.db"/>
  </cloud-backup>
  <device-transfer>
    <exclude domain="sharedpref" path="."/>
    <exclude domain="database" path="budgeting.db"/>
  </device-transfer>
</data-extraction-rules>
